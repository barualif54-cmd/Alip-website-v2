# ================= WAJIB DIISI =================
BOT_TOKEN=isi_token_bot_telegram_kamu
OWNER_CHAT_ID=isi_chat_id_kamu

# ================= OPSIONAL =================
# Daftar ID admin bot tambahan (selain OWNER_CHAT_ID), pisahkan pakai koma
ADMIN_IDS=

# Fitur /ai (Google Gemini, gratis) - tanpa ini /ai tidak akan jalan
GEMINI_API_KEY=

# Fitur /gif - tanpa ini tetap jalan pakai public beta key Giphy (gampang kena limit)
GIPHY_API_KEY=

# Fitur /pinterest (Wallhaven) - opsional, tanpa ini tetap jalan
WALLHAVEN_API_KEY=

# Mode bot: polling (default, paling gampang) atau webhook
BOT_MODE=polling

# Cuma dipakai kalau BOT_MODE=webhook
WEBHOOK_URL=
PORT=3000

# Dashboard health-check (opsional, sesuaikan sama dashboard.js kamu)
DASHBOARD_HEALTH_PATH=
DASHBOARD_HEALTH_PORT=
